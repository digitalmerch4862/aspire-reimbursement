VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OpenRouter API keys — add as many as you have (round-robin rotation)
# The AI Mode feature reads VITE_OPENROUTER_KEY_1 through VITE_OPENROUTER_KEY_N
# Free tier: ~200 requests/key/day. For 5000 req/day target, add ~25 keys.
VITE_OPENROUTER_KEY_1=your_key_here
VITE_OPENROUTER_KEY_2=your_key_here
VITE_OPENROUTER_KEY_3=your_key_here
# Add more keys as VITE_OPENROUTER_KEY_4, VITE_OPENROUTER_KEY_5, etc.
